# Server
APP_ENVIRONMENT=development
LOG_LEVEL=info

# Server Database
DATABASE_NAME=spezistudyplatform
DATABASE_USERNAME=spezistudyplatform
DATABASE_PASSWORD=spezistudyplatform
# Local development: localhost
# Docker development: host.docker.internal
DATABASE_HOST=localhost

# Keycloak
KEYCLOAK_REALM=spezistudyplatform
KEYCLOAK_CLIENT_ID=spezistudyplatform-server
KEYCLOAK_CLIENT_SECRET=dev-server-secret
KEYCLOAK_RESEARCHER_ROLE=spezistudyplatform-researcher
KEYCLOAK_PARTICIPANT_ROLE=spezistudyplatform-participant
# Local development: http://localhost:8180
# Docker development: http://host.docker.internal:8180
KEYCLOAK_URL=http://localhost:8180
